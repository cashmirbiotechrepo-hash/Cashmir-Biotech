# After installing PostgreSQL locally, create DB + tables + seed:
#   npm run db:setup
# Or: npm run db:create && npx prisma migrate deploy && npm run db:seed
#
# DATABASE_URL — local may omit pooling; production (Vercel serverless) MUST look pooled:
#   - ?connection_limit=5&pool_timeout=10  (Prisma client pool cap), and/or
#   - pgbouncer=true / Neon *-pooler.* / Supabase pooler host, and/or
#   - Prisma Accelerate (prisma+postgres://…)
# Override fail-closed pool check only for a single long-lived Node process:
#   ALLOW_UNPOOLED_DATABASE_URL="true"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashmir_biotech?schema=public&connection_limit=5&pool_timeout=10"

# At least 32 characters (used to sign the admin session JWT)
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
# Optional: dedicated Research Portal JWT secret (≥32 chars). Falls back to JWT_SECRET.
# CUSTOMER_JWT_SECRET="change-this-to-a-different-long-random-secret-32+"
# Exactly 32 characters — encrypts the session cookie (JWE)
ENCRYPTION_KEY="dev-encryption-key-32-chars-lo!!"
# HMAC pepper for admin passwords (≥32 chars in production)
PASSWORD_PEPPER="dev-only-insecure-pepper-32chars!"
ADMIN_EMAIL="admin@cashmirbiotech.com"
# Generate with: node -e "console.log(require('bcryptjs').hashSync('StrongPassword123!', 12))"
ADMIN_PASSWORD_HASH=""

# Vercel Blob for cloud file uploads (required in production for CRIT-05)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxx"

# Optional: production logging (default "info" for NODE_ENV=production)
# LOG_LEVEL=info

# Optional: Redis rate limiting & PoW storage (https://upstash.com — free tier available)
# Required in production for rate limiting & distributed PoW verification (CRIT-03, CRIT-04)
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: canonical site URL used for sitemap.xml, robots.txt and OpenGraph metadata
# NEXT_PUBLIC_SITE_URL="https://cashmirbiotech.com"

# Proof-of-work anti-bot on admin login (required in production)
# POW_SECRET="your-pow-hmac-secret"
# POW_DIFFICULTY=4
# POW_VALIDITY_MS=60000

# SMTP for portal OTP, admin 2FA, order confirmation emails (required in production)
# Gmail example (create an App Password at https://myaccount.google.com/apppasswords):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-gmail@gmail.com"
# SMTP_PASS="your-16-char-app-password"
# SMTP_FROM="Cashmir Biotech <your-gmail@gmail.com>"

# Optional: where low-stock inventory alerts are emailed (defaults to SMTP_FROM/SMTP_USER)
# INVENTORY_ALERT_EMAIL="ops@cashmirbiotech.com"

# Razorpay payments (required for the storefront checkout to work)
#   Dashboard → Settings → API Keys. Use test keys (rzp_test_...) in development.
# RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Public key exposed to the browser (usually the same value as RAZORPAY_KEY_ID)
# NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# Webhook secret from Dashboard → Settings → Webhooks (distinct from the API key secret)
# RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Optional: Sentry error tracking (@sentry/nextjs is installed — set DSN to enable)
# SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# SENTRY_AUTH_TOKEN=""  # only needed to upload source maps in CI

# E2E / Playwright money-path hooks (never enable in production)
# E2E_HOOKS_ENABLED="true"
# E2E_HOOKS_SECRET="e2e-local-secret"
# When testing checkout without Razorpay locally:
# CHECKOUT_SKIP_PAYMENT — local/E2E only. Never set on Vercel Production.
# CHECKOUT_SKIP_PAYMENT="true"
# NEXT_PUBLIC_CHECKOUT_SKIP_PAYMENT="true"
# ALLOW_CHECKOUT_SKIP_IN_PRODUCTION was removed — payment skip is hard-disabled in production.

# Cron job authentication (required in production for /api/cron/* to run)
# Vercel Cron sends this as: Authorization: Bearer <CRON_SECRET>
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Vercel Dashboard → Settings → Environment Variables
# CRON_SECRET="your-random-secret-min-16-chars"
