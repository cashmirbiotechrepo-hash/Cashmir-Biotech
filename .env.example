# After installing PostgreSQL locally, create DB + tables + seed:
#   npm run db:setup
# Or: npm run db:create && npx prisma migrate dev && npm run db:seed
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashmir_biotech?schema=public"
# At least 32 characters (used to sign the admin session JWT)
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
# Exactly 32 characters — encrypts the session cookie (JWE)
ENCRYPTION_KEY="dev-encryption-key-32-chars-lo!!"
# HMAC pepper for admin passwords (≥32 chars in production)
PASSWORD_PEPPER="dev-only-insecure-pepper-32chars!"
ADMIN_EMAIL="admin@cashmirbiotech.com"
# Generate with: node -e "console.log(require('bcryptjs').hashSync('StrongPassword123!', 12))"
ADMIN_PASSWORD_HASH=""

# Optional: production logging (default "info" for NODE_ENV=production)
# LOG_LEVEL=info

# Optional: Redis rate limiting for POST /admin/login (https://upstash.com — free tier available)
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Optional: canonical site URL used for sitemap.xml, robots.txt and OpenGraph metadata
# NEXT_PUBLIC_SITE_URL="https://cashmirbiotech.com"

# Proof-of-work anti-bot on admin login (optional in dev)
# POW_SECRET="your-pow-hmac-secret"
# POW_DIFFICULTY=4
# POW_VALIDITY_MS=60000

# SMTP for admin 2FA emails + order confirmations (required in production when 2FA is enabled)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="secret"
# SMTP_FROM="noreply@cashmirbiotech.com"

# Optional: where low-stock inventory alerts are emailed (defaults to SMTP_FROM/SMTP_USER)
# INVENTORY_ALERT_EMAIL="ops@cashmirbiotech.com"

# Razorpay payments (required for the storefront checkout to work)
#   Dashboard → Settings → API Keys. Use test keys (rzp_test_...) in development.
# RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Public key exposed to the browser (usually the same value as RAZORPAY_KEY_ID)
# NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# Webhook secret from Dashboard → Settings → Webhooks (distinct from the API key secret)
# RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Cron auth for /api/cron/release-stale-orders (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET="long-random-secret"

# DEV ONLY — skip Razorpay and mark orders paid immediately (for end-to-end checkout testing).
# Never enable in production unless ALLOW_CHECKOUT_SKIP_IN_PRODUCTION=true as well.
# CHECKOUT_SKIP_PAYMENT="true"
# ALLOW_CHECKOUT_SKIP_IN_PRODUCTION="true"
