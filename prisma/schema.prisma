generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id                       Int      @id @default(1)
  companyName              String
  heroTitle                String
  heroSubtitle             String
  heroDescription          String
  ctaPrimaryText           String
  ctaPrimaryHref           String
  ctaSecondaryText         String
  ctaSecondaryHref         String
  missionStatement         String
  /// Flat delivery fee in INR (rupees). Cart uses this until free-shipping threshold.
  flatShippingInr          Int      @default(60)
  /// Subtotal (INR) at/above which shipping is waived.
  freeShippingThresholdInr Int      @default(999)
  updatedAt                DateTime @updatedAt
}

model Product {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String
  shortBenefit      String
  description       String
  mrpInr            Int
  pricePaise        Int?          @default(0)
  sizeLabel         String
  category          String
  imageUrl          String
  images            String[]      @default([])
  sku               String        @default("")
  stockQty          Int           @default(0)
  lowStockThreshold Int           @default(10)
  leadTimeDays      Int           @default(7)
  hasInventoryTracking Boolean    @default(true)
  patentId          String?
  featured          Boolean       @default(false)
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  orderItems        OrderItem[]
  inventory         Inventory?
  certificates      CertificateOfAnalysis[]
  patent            Patent?       @relation(fields: [patentId], references: [id], onDelete: SetNull)

  @@index([patentId])
  @@unique([sku])
}

/// Catalog taxonomy (string Product.category remains denormalized label for storefront filters).
model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

/// B2B / institutional account (labs, universities).
model Organization {
  id           String   @id @default(cuid())
  name         String
  gstin        String   @default("")
  billingEmail String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  members      OrganizationMember[]
  invites      OrganizationInvite[]
  quotes       Quote[]

  @@index([active])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  role           String       @default("buyer")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, customerId])
  @@index([customerId])
}

/// Email invite to join an organisation (multi-seat).
model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String       @default("buyer")
  tokenHash      String       @unique
  invitedBy      String       @default("")
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, email])
  @@index([email])
}

model Quote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  status         String       @default("draft")
  totalCents     Int          @default(0)
  notes          String       @default("")
  poNumber       String       @default("")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

/// Lot-level Certificate of Analysis for institutional downloads.
model CertificateOfAnalysis {
  id        String         @id @default(cuid())
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  lotId     String?
  lot       InventoryLot?  @relation(fields: [lotId], references: [id], onDelete: SetNull)
  lotCode   String
  title     String
  fileUrl   String
  issuedAt  DateTime       @default(now())
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([productId, active])
  @@index([lotCode])
  @@index([lotId])
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
  payment_failed
  refunded
  partially_refunded
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerEmail   String?
  customerName    String?
  status          OrderStatus @default(pending)
  subtotalCents   Int         @default(0)
  taxCents        Int         @default(0)
  shippingCents   Int         @default(0)
  discountCents   Int?        @default(0)
  totalCents      Int         @default(0)
  couponCode      String?     @default("")
  shippingAddress Json?
  trackingNumber  String      @default("")
  carrier         String      @default("")
  shippedAt       DateTime?
  adminNotes      String      @default("")
  stockReserved   Boolean     @default(false)
  stockDeducted   Boolean     @default(false)
  /// Razorpay order id — unique when set; NULL until checkout creates a provider order.
  razorpayOrderId String?     @unique
  razorpayPaymentId String    @default("")
  customerPhone   String      @default("")
  /// Cumulative Razorpay refund amount in paise (supports partial refunds).
  refundedCents   Int         @default(0)
  customerId      String?
  /// Opaque secret required to view public confirmation / invoice pages.
  confirmationToken String    @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  invoices        Invoice[]
  paymentEvents   PaymentEvent[]
  events          OrderEvent[]
  tasks           OrderTask[]
  refunds         OrderRefund[]
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([customerId])
  @@index([customerEmail])
  @@index([confirmationToken])
}

model OrderEvent {
  id         String   @id @default(cuid())
  orderId    String
  type       String
  title      String
  detail     String   @default("")
  actorEmail String   @default("")
  metadata   Json?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String?
  productName    String
  quantity       Int
  unitPriceCents Int
  /// Comma-joined lot codes allocated at fulfillment (packing / provenance).
  lotCodes       String  @default("")
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lotAllocations OrderItemLotAllocation[]

  @@index([orderId])
}

/// FEFO lot draw-down recorded per order line at payment confirmation.
model OrderItemLotAllocation {
  id          String       @id @default(cuid())
  orderItemId String
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  lotId       String
  lot         InventoryLot @relation(fields: [lotId], references: [id], onDelete: Restrict)
  quantity    Int
  createdAt   DateTime     @default(now())

  @@index([orderItemId])
  @@index([lotId])
}

model PaymentEvent {
  id             String    @id @default(cuid())
  eventType      String
  providerEventId String   @unique
  orderId        String?
  signatureValid Boolean   @default(false)
  payload        Json?
  /// Set after fulfillment succeeds — NULL means recorded but incomplete (re-driveable).
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  order          Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

/// One row per Razorpay refund entity — prevents double-counting across webhook events and admin actions.
model OrderRefund {
  id               String   @id @default(cuid())
  orderId          String
  razorpayRefundId String   @unique
  amountCents      Int
  source           String   /// admin, webhook
  stockRestored    Boolean  @default(false)
  createdAt        DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

/// Database-backed outbox for async post-payment side-effects (P-03).
/// Webhook acks fast after durable payment receipt; cron polls this table for PDF/email/customer work.
model OrderTask {
  id        String   @id @default(cuid())
  orderId   String
  type      String   /// post_payment, send_email, generate_invoice, etc.
  status    String   @default("pending") /// pending, processing, completed, failed, dead_letter
  attempts  Int      @default(0)
  lastError String   @default("")
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([orderId])
  @@unique([orderId, type])
}

enum InventoryChangeType {
  initial_stock
  order_placed
  order_confirmed
  order_cancelled
  order_returned
  manual_adjustment
  restock
  damaged
}

model Inventory {
  id                String                 @id @default(cuid())
  productId         String                 @unique
  sku               String                 @default("")
  quantityOnHand    Int                    @default(0)
  quantityReserved  Int                    @default(0)
  lowStockThreshold Int                    @default(10)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  product           Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  transactions      InventoryTransaction[]
  lots              InventoryLot[]

  @@index([sku])
}

/// Physical lot/batch with expiry — source of truth for packing slip provenance.
model InventoryLot {
  id             String                   @id @default(cuid())
  inventoryId    String
  inventory      Inventory                @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  lotCode        String
  quantityOnHand Int                      @default(0)
  manufacturedAt DateTime?
  expiresAt      DateTime?
  notes          String                   @default("")
  active         Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  allocations    OrderItemLotAllocation[]
  certificates   CertificateOfAnalysis[]

  @@unique([inventoryId, lotCode])
  @@index([inventoryId, expiresAt])
  @@index([lotCode])
}

model InventoryTransaction {
  id             String              @id @default(cuid())
  inventoryId    String
  changeType     InventoryChangeType
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  reservedAfter  Int                 @default(0)
  referenceType  String              @default("manual")
  referenceId    String?
  note           String              @default("")
  createdBy      String?
  createdAt      DateTime            @default(now())
  inventory      Inventory           @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId, createdAt])
  @@index([referenceType, referenceId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userEmail  String
  action     String
  entityType String
  entityId   String?
  diff       Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, createdAt])
  @@index([userEmail, createdAt])
  @@index([createdAt])
}

model MediaAsset {
  id         String   @id @default(cuid())
  url        String
  type       String   @default("image")
  altText    String   @default("")
  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

enum BlogPostStatus {
  draft
  published
  archived
}

model BlogPost {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  excerpt       String         @default("")
  coverImageUrl String         @default("")
  body          String         @default("")
  status        BlogPostStatus @default(draft)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Patent {
  id                String    @id @default(cuid())
  patentCode        String    @unique
  applicationNumber String    @default("")
  title             String
  summary           String
  status            String
  lifecycleStatus   PatentLifecycle @default(granted)
  jurisdiction      String
  country           String    @default("")
  imageUrl          String    @default("")
  documentUrl       String    @default("")
  inventors         Json      @default("[]")
  filedAt           DateTime?
  grantedAt         DateTime?
  publishedAt       DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  products          Product[]

  @@index([lifecycleStatus, publishedAt])
}

enum PatentLifecycle {
  pending
  granted
  expired
}

enum ContactType {
  lead
  customer
  partner
}

enum DealStage {
  lead
  qualified
  proposal
  won
  lost
}

model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  company   String      @default("")
  phone     String      @default("")
  type      ContactType @default(lead)
  notes     String      @default("")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deals     Deal[]

  @@index([type, createdAt])
}

model Deal {
  id              String    @id @default(cuid())
  contactId       String
  title           String
  stage           DealStage @default(lead)
  valueCents      Int       @default(0)
  expectedCloseAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([stage, expectedCloseAt])
  @@index([contactId])
}

enum CouponType {
  percent
  fixed
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Int
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([active, expiresAt])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  /// One invoice per order — uniqueness prevents race duplicates.
  orderId       String?  @unique
  subtotalCents Int      @default(0)
  taxCents      Int      @default(0)
  totalCents    Int      @default(0)
  gstDetails    Json
  pdfUrl        String   @default("")
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([issuedAt])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  category    String
  amountCents Int
  gstCents    Int      @default(0)
  vendor      String   @default("")
  notes       String   @default("")
  incurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([incurredAt])
  @@index([category])
}

enum CampaignStatus {
  draft
  sent
}

model EmailCampaign {
  id             String         @id @default(cuid())
  name           String
  subject        String
  body           String
  status         CampaignStatus @default(draft)
  recipientCount Int            @default(0)
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  fullName    String
  role        String
  bio         String
  avatarUrl   String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String    @default("homepage")
  status         String    @default("subscribed")
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
}

enum AdminRole {
  owner
  admin
  editor
}

model AdminUser {
  id                  String         @id @default(cuid())
  email               String         @unique
  passwordHash        String
  name                String         @default("")
  role                AdminRole      @default(admin)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  twoFactorSecret     String?
  twoFactorExpires    DateTime?
  twoFactorAttempts   Int            @default(0)
  isTwoFactorEnabled  Boolean        @default(false)
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  sessions            AdminSession[]

  @@index([email])
}

model AdminSession {
  id            String              @id @default(cuid())
  userId        String
  ipAddress     String?
  userAgent     String?             @db.VarChar(500)
  createdAt     DateTime            @default(now())
  expiresAt     DateTime
  lastUsedAt    DateTime            @default(now())
  isRevoked     Boolean             @default(false)
  user          AdminUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens AdminRefreshToken[]

  @@index([userId, isRevoked])
}

model AdminRefreshToken {
  id        String       @id @default(cuid())
  sessionId String
  tokenHash String       @unique
  expiresAt DateTime
  revoked   Boolean      @default(false)
  createdAt DateTime     @default(now())
  session   AdminSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

/// Storefront Research Portal — completely separate from AdminUser.
model Customer {
  id                  String             @id @default(cuid())
  email               String             @unique
  passwordHash        String?  /// Legacy residue — portal auth is OTP-only; do not use for login.
  name                String?
  phone               String?
  emailVerifiedAt     DateTime?
  active              Boolean            @default(true)
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  orders              Order[]
  sessions            CustomerSession[]
  otps                CustomerOtp[]
  addresses           CustomerAddress[]
  supportTickets      SupportTicket[]
  organizationMembers OrganizationMember[]
  circleSubscriptions ResearchCircleSubscription[]
}

/// Research Circle membership plan (annual / multi-month).
model ResearchCirclePlan {
  id             String                       @id @default(cuid())
  slug           String                       @unique
  name           String
  description    String                       @default("")
  priceCents     Int
  intervalMonths Int                          @default(12)
  benefits       String                       @default("")
  active         Boolean                      @default(true)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  subscriptions  ResearchCircleSubscription[]

  @@index([active])
}

model ResearchCircleSubscription {
  id                 String             @id @default(cuid())
  customerId         String
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  planId             String
  plan               ResearchCirclePlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  status             String             @default("active")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  razorpayPaymentId  String?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([customerId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model SupportTicket {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderNumber String  @default("")
  topic      String
  subject    String
  body       String
  status     String   @default("open")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model CustomerSession {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?  @db.VarChar(500)
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([customerId, isRevoked])
}

model CustomerOtp {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email      String
  codeHash   String
  purpose    String    @default("login")
  expiresAt  DateTime
  attempts   Int       @default(0)
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String   @default("Home")
  fullName   String   @default("")
  phone      String   @default("")
  line1      String
  line2      String   @default("")
  city       String
  state      String
  postalCode String
  country    String   @default("India")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}
