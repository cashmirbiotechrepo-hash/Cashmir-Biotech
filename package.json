{
  "name": "cashmir-biotech-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json}\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:create": "tsx scripts/ensure-database.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset-admin": "node --env-file=.env --import tsx scripts/reset-admin.ts",
    "db:setup": "npm run db:create && prisma migrate deploy && npm run db:seed",
    "aws:secrets": "powershell -File ./scripts/aws/generate-secrets.ps1",
    "aws:env": "powershell -File ./scripts/aws/prepare-amplify-env.ps1",
    "aws:amplify": "powershell -File ./scripts/aws/connect-amplify.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@base-ui/react": "^1.6.0",
    "@gsap/react": "^2.1.2",
    "@paper-design/shaders-react": "^0.0.77",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@sentry/nextjs": "^10.65.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "jose": "^5.9.6",
    "lenis": "^1.3.25",
    "lucide-react": "^0.468.0",
    "motion": "^12.38.0",
    "next": "15.5.20",
    "next-themes": "^0.4.3",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use-measure": "^2.1.7",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.169.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bwip-js": "^3.2.3",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^29.1.1",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20"
  }
}
